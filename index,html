        class Measurement {
            static measure(state, qubit = null) {
                if (qubit === null || qubit === undefined) return this.measureAll(state);
                if (qubit < 0 || qubit >= state.numQubits) throw new Error("Measurement qubit out of range");
                const mask = 1 << qubit;
                const p1 = state.amplitudes.reduce((sum, amp, index) => sum + ((index & mask) ? amp.abs2() : 0), 0);
                const outcome = Math.random() < p1 ? 1 : 0;
                const keepProb = outcome ? p1 : 1 - p1;
                const scale = keepProb > 0 ? 1 / Math.sqrt(keepProb) : 0;
                state.amplitudes = state.amplitudes.map((amp, index) => {
                    const bit = (index & mask) ? 1 : 0;
                    return bit === outcome ? amp.scale(scale) : Complex.zero();
                });
                return { type: "qubit", qubit, outcome, probability: keepProb };
            }

            static measureAll(state) {
                const probabilities = state.probabilities();
                let roll = Math.random();
                let chosen = probabilities[probabilities.length - 1];
                for (const item of probabilities) {
                    roll -= item.probability;
                    if (roll <= 0) {
                        chosen = item;
                        break;
                    }
                }
                state.amplitudes = state.amplitudes.map((_, index) => new Complex(index === chosen.index ? 1 : 0, 0));
                return {
                    type: "all",
                    index: chosen.index,
                    bitstring: chosen.index.toString(2).padStart(state.numQubits, "0"),
                    probability: chosen.probability
                };
            }
        }

        window.Measurement = Measurement;


        class QuantumState {
            constructor(numQubits) {
                if (numQubits < 1 || numQubits > 8) throw new Error("QuantumState supports 1 to 8 qubits");
                this.numQubits = numQubits;
                this.size = 1 << numQubits;
                this.amplitudes = Array.from({ length: this.size }, (_, i) => new Complex(i === 0 ? 1 : 0, 0));
            }

            clone() {
                const copy = new QuantumState(this.numQubits);
                copy.amplitudes = this.amplitudes.map((amp) => amp.clone());
                return copy;
            }

            basisLabel(index) {
                return `|${index.toString(2).padStart(this.numQubits, "0")}>`;
            }

            probabilities() {
                return this.amplitudes.map((amp, index) => ({
                    index,
                    label: this.basisLabel(index),
                    probability: amp.abs2(),
                    amplitude: amp
                }));
            }

            normalize() {
                const norm = Math.sqrt(this.amplitudes.reduce((sum, amp) => sum + amp.abs2(), 0));
                if (norm === 0) throw new Error("Cannot normalize a zero state");
                this.amplitudes = this.amplitudes.map((amp) => amp.scale(1 / norm));
            }

            applySingleQubitGate(matrix, target) {
                const mask = 1 << target;
                const next = this.amplitudes.map((amp) => amp.clone());
                for (let i = 0; i < this.size; i++) {
                    if ((i & mask) !== 0) continue;
                    const j = i | mask;
                    const a0 = this.amplitudes[i];
                    const a1 = this.amplitudes[j];
                    next[i] = matrix.rows[0][0].mul(a0).add(matrix.rows[0][1].mul(a1));
                    next[j] = matrix.rows[1][0].mul(a0).add(matrix.rows[1][1].mul(a1));
                }
                this.amplitudes = next;
            }

            applyCNOT(control, target) {
                if (control === target) throw new Error("CNOT control and target must differ");
                const cMask = 1 << control;
                const tMask = 1 << target;
                const next = this.amplitudes.map((amp) => amp.clone());
                for (let i = 0; i < this.size; i++) {
                    if ((i & cMask) && !(i & tMask)) {
                        const j = i | tMask;
                        next[i] = this.amplitudes[j].clone();
                        next[j] = this.amplitudes[i].clone();
                    }
                }
                this.amplitudes = next;
            }

            applySWAP(a, b) {
                if (a === b) throw new Error("SWAP targets must differ");
                const aMask = 1 << a;
                const bMask = 1 << b;
                const next = this.amplitudes.map((amp) => amp.clone());
                for (let i = 0; i < this.size; i++) {
                    const abit = Boolean(i & aMask);
                    const bbit = Boolean(i & bMask);
                    if (abit === bbit) continue;
                    const j = i ^ aMask ^ bMask;
                    if (i < j) {
                        next[i] = this.amplitudes[j].clone();
                        next[j] = this.amplitudes[i].clone();
                    }
                }
                this.amplitudes = next;
            }

            measure(qubit = null) {
                return Measurement.measure(this, qubit);
            }

            // ===== NEW: set state from sensor (added, does not modify existing) =====
            setSensorState(type) {
                if (type === '|0⟩') {
                    this.amplitudes = Array.from({ length: this.size }, (_, i) => new Complex(i === 0 ? 1 : 0, 0));
                } else if (type === '|1⟩') {
                    this.amplitudes = Array.from({ length: this.size }, (_, i) => new Complex(i === 1 ? 1 : 0, 0));
                } else if (type === '|ψ⟩') {
                    const s = 1 / Math.sqrt(2);
                    this.amplitudes = Array.from({ length: this.size }, (_, i) => new Complex(i === 0 || i === 1 ? s : 0, 0));
                } else {
                    // IDLE → reset to |0⟩
                    this.amplitudes = Array.from({ length: this.size }, (_, i) => new Complex(i === 0 ? 1 : 0, 0));
                }
                this.normalize();
            }
        }

