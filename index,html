<!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>GROWWIN QUANTUM EMULATOR + SENSOR</title>
    <style>
        /* ===== ORIGINAL EMULATOR STYLES (unchanged) ===== */
        :root {
            color-scheme: dark;
            --bg: #0e1117;
            --panel: #151a23;
            --panel-2: #1b2230;
            --text: #eef4ff;
            --muted: #93a1b7;
            --line: rgba(255, 255, 255, .12);
            --accent: #3ddc97;
            --danger: #ff6b6b;
            --shadow: 0 18px 48px rgba(0, 0, 0, .32);
            --gold: #ffea00;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: Inter, ui-sans-serif, system-ui, -apple-system, Segoe UI, Arial, sans-serif;
            background: radial-gradient(circle at 30% 0%, rgba(61, 220, 151, .14), transparent 32%), var(--bg);
            color: var(--text);
        }

        button,
        textarea {
            font: inherit;
        }

        button {
            cursor: pointer;
        }

        .app-shell {
            width: min(1600px, 100%);
            margin: 0 auto;
            padding: 20px;
        }

        .topbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 18px;
            padding: 16px 18px;
            background: rgba(21, 26, 35, .92);
            border: 1px solid var(--line);
            border-radius: 8px;
            box-shadow: var(--shadow);
            flex-wrap: wrap;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 14px;
            min-width: 260px;
        }

        .logo {
            width: 44px;
            height: 44px;
            display: grid;
            place-items: center;
            border-radius: 8px;
            background: linear-gradient(135deg, #3ddc97, #34b3f1);
            color: #071014;
            font-weight: 900;
            letter-spacing: 0;
        }

        h1,
        h2,
        h3,
        p {
            margin: 0;
        }

        h1 {
            font-size: clamp(18px, 3vw, 26px);
            letter-spacing: 0;
        }

        .brand p,
        .muted {
            color: var(--muted);
            font-size: 13px;
        }

        .status-strip {
            display: grid;
            grid-template-columns: repeat(4, minmax(100px, 1fr));
            gap: 10px;
            flex: 1;
        }

        .status-item {
            min-height: 52px;
            padding: 10px;
            background: var(--panel-2);
            border: 1px solid var(--line);
            border-radius: 8px;
        }

        .status-item span {
            display: block;
            color: var(--muted);
            font-size: 12px;
            margin-bottom: 3px;
        }

        .status-item strong {
            font-size: 15px;
        }

        .status-item .error {
            color: var(--danger);
        }

        .error {
            color: var(--danger);
        }

        .layout {
            display: grid;
            grid-template-columns: 260px minmax(0, 1fr) 360px;
            gap: 16px;
            margin-top: 16px;
        }

        .panel {
            background: rgba(21, 26, 35, .94);
            border: 1px solid var(--line);
            border-radius: 8px;
            box-shadow: var(--shadow);
            overflow: hidden;
        }

        .panel-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            padding: 14px 16px;
            border-bottom: 1px solid var(--line);
        }

        .panel-header h2,
        .panel-header h3 {
            font-size: 15px;
        }

        .panel-body {
            padding: 14px;
        }

        .sidebar {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .gate-palette {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 10px;
        }

        .gate-chip {
            height: 42px;
            border: 1px solid color-mix(in srgb, var(--gate-color), white 18%);
            border-radius: 8px;
            background: color-mix(in srgb, var(--gate-color), #111827 68%);
            color: white;
            font-weight: 800;
        }

        .gate-chip.active {
            outline: 2px solid white;
            outline-offset: 2px;
        }

        .toolbar,
        .export-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        .btn {
            min-height: 38px;
            border: 1px solid var(--line);
            background: #202839;
            color: var(--text);
            border-radius: 8px;
            padding: 8px 11px;
            font-weight: 700;
        }

        .btn.primary {
            background: linear-gradient(135deg, #3ddc97, #34b3f1);
            color: #071014;
            border: 0;
        }

        .btn.danger {
            background: #3a2028;
            color: #ffdce1;
        }

        .btn.gold {
            background: linear-gradient(135deg, #ffea00, #ffb300);
            color: #071014;
            border: 0;
        }

        .circuit-wrap {
            overflow: auto;
            padding: 8px;
        }

        .circuit-grid {
            display: grid;
            gap: 0;
            min-width: 720px;
        }

        .qubit-label {
            height: 62px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--muted);
            font-weight: 800;
            border-right: 1px solid var(--line);
        }

        .circuit-cell {
            position: relative;
            height: 62px;
            min-width: 54px;
            display: grid;
            place-items: center;
            border-right: 1px solid rgba(255, 255, 255, .06);
        }

        .wire {
            position: absolute;
            left: 0;
            right: 0;
            top: 50%;
            height: 2px;
            background: rgba(238, 244, 255, .28);
        }

        .circuit-cell.connector::before {
            content: "";
            position: absolute;
            top: 0;
            bottom: 0;
            width: 2px;
            background: rgba(84, 209, 219, .7);
        }

        .gate-node {
            position: relative;
            z-index: 2;
            width: 38px;
            height: 38px;
            border: 0;
            border-radius: 8px;
            color: #081014;
            font-weight: 900;
            box-shadow: 0 10px 20px rgba(0, 0, 0, .28);
        }

        .gate-node.multi {
            border-radius: 50%;
        }

        .results {
            display: grid;
            gap: 16px;
        }

        .bar-row {
            display: grid;
            grid-template-columns: 54px 1fr 70px;
            gap: 8px;
            align-items: center;
            margin-bottom: 8px;
            font-size: 12px;
        }

        .bar-track {
            height: 12px;
            background: #273044;
            border-radius: 999px;
            overflow: hidden;
        }

        .bar-fill {
            height: 100%;
            background: linear-gradient(90deg, #3ddc97, #34b3f1);
        }

        .bar-value {
            color: var(--muted);
            text-align: right;
        }

        .amplitude-canvas {
            width: 100%;
            height: 180px;
            display: block;
            background: #101620;
            border: 1px solid var(--line);
            border-radius: 8px;
        }

        .table-wrap {
            max-height: 300px;
            overflow: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 12px;
        }

        th,
        td {
            padding: 8px;
            border-bottom: 1px solid rgba(255, 255, 255, .08);
            text-align: left;
            white-space: nowrap;
        }

        th {
            color: var(--muted);
            position: sticky;
            top: 0;
            background: var(--panel);
        }

        .stat-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 8px;
        }

        .stat-pill {
            display: flex;
            justify-content: space-between;
            gap: 8px;
            padding: 9px 10px;
            border: 1px solid var(--line);
            border-radius: 8px;
            background: #111722;
            font-size: 13px;
        }

        textarea {
            width: 100%;
            min-height: 150px;
            resize: vertical;
            border: 1px solid var(--line);
            border-radius: 8px;
            background: #101620;
            color: var(--text);
            padding: 10px;
            line-height: 1.45;
        }

        textarea.code-input {
            min-height: 120px;
            font-family: 'Courier New', monospace;
            font-size: 13px;
        }

        .export-panel {
            margin-top: 16px;
        }

        /* ===== SENSOR PANEL STYLES (from second code, adapted) ===== */
        .sensor-box {
            position: relative;
            border-radius: 8px;
            overflow: hidden;
            background: #000;
            border: 1px solid var(--line);
        }

        .sensor-box video {
            width: 100%;
            height: auto;
            display: block;
            filter: contrast(1.2) brightness(1.1);
        }

        .pin-target {
            position: absolute;
            top: 50%;
            left: 50%;
            width: 40px;
            height: 40px;
            border: 2px dashed var(--gold);
            transform: translate(-50%, -50%);
            border-radius: 5px;
            pointer-events: none;
            z-index: 10;
        }

        #spectrometer {
            width: 100%;
            height: 90px;
            background: #000;
            border: 1px solid #333;
            border-radius: 5px;
            margin-top: 8px;
            display: block;
        }

        .qubit-card {
            margin-bottom: 12px;
            padding: 12px 14px;
            border-radius: 8px;
            border-left: 5px solid #444;
            background: #0a0c10;
            color: var(--text);
        }

        .qubit-card small {
            color: var(--muted);
            font-size: 11px;
        }

        .qubit-card .big {
            font-size: 1.4rem;
            font-weight: 700;
        }

        .qubit-card .gold {
            color: var(--gold);
        }

        #bloch-stage {
            width: 100%;
            margin-top: 12px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            border-top: 1px solid #222;
            padding-top: 14px;
        }

        #bloch-stage small {
            color: #555;
            margin-bottom: 8px;
            font-size: 11px;
            letter-spacing: 1px;
        }

        #vector-container {
            width: 160px;
            height: 160px;
            perspective: 800px;
            position: relative;
        }

        #vector-circle {
            width: 100%;
            height: 100%;
            border: 1px solid rgba(0, 255, 204, 0.3);
            border-radius: 50%;
            position: relative;
            background: radial-gradient(circle at 30% 30%, #1a1f29, #000);
            transform-style: preserve-3d;
            transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
        }

        #vector-circle::before,
        #vector-circle::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            border: 1px solid rgba(0, 255, 204, 0.15);
            border-radius: 50%;
        }

        #vector-circle::before {
            transform: rotateY(90deg);
        }

        #vector-circle::after {
            transform: rotateX(90deg);
        }

        .needle {
            width: 3px;
            height: 80px;
            position: absolute;
            left: 78.5px;
            top: 0;
            transform-origin: bottom;
            transition: 0.3s;
            opacity: 0.2;
            border-radius: 2px;
        }

        #n-red {
            background: #ff4b2b;
        }

        #n-white {
            background: #ffffff;
        }

        #n-main {
            background: var(--gold);
            width: 4px;
            opacity: 1;
            box-shadow: 0 0 20px var(--gold);
            z-index: 5;
            transform: translateZ(35px);
        }

        #q-sym {
            position: absolute;
            width: 100%;
            text-align: center;
            top: 60px;
            color: rgba(255, 234, 0, 0.7);
            font-size: 2.2rem;
            font-weight: bold;
            pointer-events: none;
            z-index: 6;
            text-shadow: 0 0 10px #000;
        }

        .active-row {
            background: #004466 !important;
            color: #fff !important;
            box-shadow: inset 0 0 15px var(--accent);
        }

        .val-changing {
            color: var(--gold) !important;
            text-shadow: 0 0 12px var(--gold);
            transition: color 0.1s;
        }

        .truth-table {
            margin: 16px auto 0;
            width: 100%;
            border-collapse: collapse;
            background: #111;
            font-size: 13px;
        }

        .truth-table th,
        .truth-table td {
            border: 1px solid #222;
            padding: 10px 12px;
            color: var(--text);
        }

        .truth-table th {
            color: var(--muted);
            font-weight: 600;
        }

        .truth-table .ev-val {
            color: var(--gold);
            font-size: 0.8rem;
            margin-left: 6px;
            display: none;
        }

        .sensor-controls {
            display: flex;
            gap: 10px;
            align-items: center;
            margin: 8px 0;
        }

        .sensor-controls label {
            font-size: 0.7rem;
            color: #888;
        }

        .sensor-controls input[type="range"] {
            flex: 1;
            accent-color: var(--accent);
        }

        .sensor-status-badge {
            display: inline-block;
            padding: 2px 12px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 700;
            background: #2a2a2a;
            color: #888;
        }

        .sensor-status-badge.on {
            background: #1a4a3a;
            color: var(--accent);
        }

        /* RESPONSIVE (unchanged from original) */
        @media (max-width: 1180px) {
            .layout {
                grid-template-columns: 240px minmax(0, 1fr);
            }
            .results {
                grid-column: 1 / -1;
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @media (max-width: 760px) {
            .app-shell {
                padding: 10px;
            }
            .topbar,
            .layout,
            .results {
                grid-template-columns: 1fr;
            }
            .topbar {
                display: grid;
            }
            .status-strip {
                grid-template-columns: repeat(2, 1fr);
            }
            .sidebar {
                order: 2;
            }
        }
    </style>
</head>

<body>

    <main class="app-shell">

        <!-- TOPBAR -->
        <header class="topbar">
            <div class="brand" aria-label="GrowWin Quantum Emulator">
                <div class="logo">GW</div>
                <div>
                    <h1>GROWWIN QUANTUM EMULATOR</h1>
                    <p></p>
                </div>
            </div>
            <section class="status-strip" aria-label="Simulation status">
                <div class="status-item"><span>Status</span><strong id="statusText">Ready</strong></div>
                <div class="status-item"><span>Execution</span><strong id="timingText">0.000 ms</strong></div>
                <div class="status-item"><span>Qubits</span><strong id="qCount">2</strong></div>
                <div class="status-item"><span>Gates</span><strong id="gateCount">0</strong></div>
            </section>
        </header>

        <section class="layout">
            <!-- LEFT SIDEBAR (unchanged) -->
            <aside class="sidebar">
                <section class="panel">
                    <div class="panel-header"><h2>Gate Palette</h2><span class="muted">Drag or click</span></div>
                    <div class="panel-body">
                        <div id="gatePalette" class="gate-palette"></div>
                    </div>
                </section>

                <section class="panel">
                    <div class="panel-header"><h2>Controls</h2><span class="muted"><span id="columns">8</span> columns</span></div>
                    <div class="panel-body toolbar">
                        <button class="btn" id="addQubit">Add Qubit</button>
                        <button class="btn" id="removeQubit">Remove Qubit</button>
                        <button class="btn" id="addColumn">Add Column</button>
                        <button class="btn primary" id="runCircuit">Run Circuit</button>
                        <button class="btn" id="measureAll">Measure</button>
                        <button class="btn" id="randomCircuit">Random</button>
                        <button class="btn danger" id="resetCircuit">Reset</button>
                    </div>
                </section>

                <section class="panel">
                    <div class="panel-header"><h2>Gate Statistics</h2></div>
                    <div class="panel-body">
                        <div id="gateStats" class="stat-grid"></div>
                    </div>
                </section>
            </aside>

            <!-- CENTER (unchanged) -->
            <section>
                <section class="panel">
                    <div class="panel-header">
                        <h2>Quantum Circuit Editor</h2>
                        <span class="muted">Two-qubit gates: select first qubit, then second qubit in the same column</span>
                    </div>
                    <div class="circuit-wrap">
                        <div id="circuitGrid" class="circuit-grid" aria-label="Quantum circuit grid"></div>
                    </div>
                </section>

                <section class="panel export-panel">
                    <div class="panel-header"><h2>Import / Export</h2></div>
                    <div class="panel-body">
                        <div class="export-actions">
                            <button class="btn" id="exportJson">Export JSON</button>
                            <button class="btn" id="exportQasm">Export OpenQASM</button>
                            <button class="btn" id="exportQiskit">Export Qiskit</button>
                            <button class="btn primary" id="importJson">Import JSON</button>
                        </div>
                        <p class="muted" style="margin: 12px 0 8px;">Export output</p>
                        <textarea id="exportText" spellcheck="false"></textarea>
                        <p class="muted" style="margin: 12px 0 8px;">Import JSON</p>
                        <textarea id="importText" spellcheck="false" placeholder='{"numQubits":2,"columns":8,"gates":[{"type":"H","column":0,"targets":[0]}]}'></textarea>
                    </div>
                </section>

                <section class="panel export-panel">
                    <div class="panel-header"><h2>Circuit Code Input</h2><span id="circuitCodeMessage" class="muted">Paste Qiskit or OpenQASM gate lines</span></div>
                    <div class="panel-body">
                        <textarea id="circuitCodeInput" class="code-input" spellcheck="false" placeholder="qc.h(0)&#10;qc.x(1)&#10;qc.cx(0,1)&#10;qc.z(0)&#10;qc.swap(0,1)"></textarea>
                        <div class="export-actions" style="margin-top: 10px;">
                            <button class="btn" id="buildCircuitFromCode">Build Circuit</button>
                            <button class="btn primary" id="runImportedCircuit">Run Imported Circuit</button>
                        </div>
                    </div>
                </section>
            </section>

            <!-- RIGHT: RESULTS + SENSOR -->
            <section class="results">

                <!-- ===== ORIGINAL EMULATOR PANELS (unchanged) ===== -->
                <section class="panel">
                    <div class="panel-header"><h2>Probabilities</h2><span id="measurementText" class="muted">No measurement yet</span></div>
                    <div class="panel-body"><div id="probabilityChart"></div></div>
                </section>

                <section class="panel">
                    <div class="panel-header"><h2>Amplitudes</h2><span class="muted">Magnitude and phase</span></div>
                    <div class="panel-body"><canvas id="amplitudeCanvas" class="amplitude-canvas"></canvas></div>
                </section>

                <section class="panel">
                    <div class="panel-header"><h2>Quantum State</h2></div>
                    <div class="panel-body table-wrap" id="stateTable"></div>
                </section>

                <!-- ===== NEW SENSOR PANEL (added, does not modify existing) ===== -->
                <section class="panel">
                    <div class="panel-header">
                        <h2>🔬 Quantum Pin‑Point Sensor</h2>
                        <span id="sensorStatusBadge" class="sensor-status-badge">⏻ IDLE</span>
                    </div>
                    <div class="panel-body">
                        <div class="sensor-box">
                            <video id="video" autoplay playsinline muted></video>
                            <div class="pin-target"></div>
                            <canvas id="canvas" width="540" height="405" style="display:none;"></canvas>
                        </div>
                        <canvas id="spectrometer"></canvas>

                        <div class="sensor-controls">
                            <label>SENSITIVITY</label>
                            <input type="range" id="sens" min="30" max="240" value="110">
                            <button class="btn primary" id="sensorStartBtn" style="padding:4px 14px;">START</button>
                            <button class="btn danger" id="sensorStopBtn" style="padding:4px 14px;">STOP</button>
                        </div>

                        <div class="qubit-card" style="border-left-color:var(--accent);">
                            <small>SYSTEM STATUS</small>
                            <div id="q-status" style="font-size:1.2rem;margin-top:4px;font-weight:700;">IDLE</div>
                        </div>

                        <div class="qubit-card" style="border-left-color:#00aaff;">
                            <small>HARMONIC FREQUENCY</small>
                            <div id="hz-text" style="font-size:1.4rem;color:var(--gold);">0 Hz</div>
                            <div id="detect-text" style="font-size:0.8rem;color:#00aaff;">Scanning for Quantum Gates…</div>
                        </div>

                        <div id="bloch-stage">
                            <small>3D BLOCH SPHERE — SENSOR STATE</small>
                            <div id="vector-container">
                                <div id="vector-circle">
                                    <div id="q-sym"></div>
                                    <div id="n-white" class="needle"></div>
                                    <div id="n-red" class="needle" style="transform:rotate(180deg)"></div>
                                    <div id="n-main" class="needle"></div>
                                </div>
                            </div>
                        </div>

                        <!-- Truth Table (sensor detection) -->
                        <table class="truth-table" id="t-table">
                            <thead>
                                <tr>
                                    <th>DETECTION</th>
                                    <th>Frequency (THz)</th>
                                    <th>Energy State (eV)</th>
                                    <th>QUANTUM STATE</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr id="row-red">
                                    <td>Red Signal</td>
                                    <td><span id="f-red">0</span></td>
                                    <td>Low Energy State <span id="ev-red" class="ev-val">(1.95eV)</span></td>
                                    <td style="font-size:1.2rem;font-weight:bold;">|0⟩</td>
                                </tr>
                                <tr id="row-white">
                                    <td>White Signal</td>
                                    <td><span id="f-white">0</span></td>
                                    <td>High Energy State <span id="ev-white" class="ev-val">(2.75eV)</span></td>
                                    <td style="font-size:1.2rem;font-weight:bold;">|1⟩</td>
                                </tr>
                                <tr id="row-super">
                                    <td>Dual Signal</td>
                                    <td><span id="f-super">0</span></td>
                                    <td>Superposition State <span id="ev-super" class="ev-val">(1.95eV - 2.75eV)</span></td>
                                    <td style="font-size:1.2rem;font-weight:bold;">|ψ⟩</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </section>

            </section>
        </section>

    </main>

    <!-- ============================================================ -->
    <!-- 1. QUANTUM EMULATOR CORE (EXACTLY AS PROVIDED, UNCHANGED)     -->
    <!-- ============================================================ -->
    <script>
        // ---- START OF ORIGINAL EMULATOR CODE (unchanged) ----
        class Complex {
            constructor(re = 0, im = 0) {
                this.re = Number(re) || 0;
                this.im = Number(im) || 0;
            }

            static from(value) {
                return value instanceof Complex ? value : new Complex(value, 0);
            }

            static zero() {
                return new Complex(0, 0);
            }

            static one() {
                return new Complex(1, 0);
            }

            clone() {
                return new Complex(this.re, this.im);
            }

            add(other) {
                other = Complex.from(other);
                return new Complex(this.re + other.re, this.im + other.im);
            }

            sub(other) {
                other = Complex.from(other);
                return new Complex(this.re - other.re, this.im - other.im);
            }

            mul(other) {
                other = Complex.from(other);
                return new Complex(
                    this.re * other.re - this.im * other.im,
                    this.re * other.im + this.im * other.re
                );
            }

            div(other) {
                other = Complex.from(other);
                const denom = other.re * other.re + other.im * other.im;
                if (denom === 0) throw new Error("Complex division by zero");
                return new Complex(
                    (this.re * other.re + this.im * other.im) / denom,
                    (this.im * other.re - this.re * other.im) / denom
                );
            }

            scale(factor) {
                return new Complex(this.re * factor, this.im * factor);
            }

            conj() {
                return new Complex(this.re, -this.im);
            }

            abs2() {
                return this.re * this.re + this.im * this.im;
            }

            abs() {
                return Math.sqrt(this.abs2());
            }

            phase() {
                return Math.atan2(this.im, this.re);
            }

            isNearZero(epsilon = 1e-12) {
                return Math.abs(this.re) < epsilon && Math.abs(this.im) < epsilon;
            }

            toJSON() {
                return { re: this.re, im: this.im };
            }

            toString(precision = 4) {
                const clean = (n) => {
                    if (Math.abs(n) < 1e-12) n = 0;
                    return Number(n.toFixed(precision)).toString();
                };
                const re = clean(this.re);
                const im = clean(Math.abs(this.im));
                if (Math.abs(this.im) < 1e-12) return re;
                if (Math.abs(this.re) < 1e-12) return `${this.im < 0 ? "-" : ""}${im}i`;
                return `${re} ${this.im < 0 ? "-" : "+"} ${im}i`;
            }
        }

        window.Complex = Complex;


        class Matrix {
            constructor(rows) {
                if (!Array.isArray(rows) || rows.length === 0) throw new Error("Matrix requires rows");
                const width = rows[0].length;
                if (!width || rows.some((row) => row.length !== width)) throw new Error("Matrix rows must be rectangular");
                this.rows = rows.map((row) => row.map((value) => Complex.from(value)));
                this.height = rows.length;
                this.width = width;
            }

            static identity(size) {
                return new Matrix(Array.from({ length: size }, (_, r) =>
                    Array.from({ length: size }, (_, c) => new Complex(r === c ? 1 : 0, 0))
                ));
            }

            static zeros(height, width) {
                return new Matrix(Array.from({ length: height }, () =>
                    Array.from({ length: width }, () => Complex.zero())
                ));
            }

            multiply(other) {
                if (this.width !== other.height) throw new Error("Matrix dimensions do not match");
                const output = [];
                for (let r = 0; r < this.height; r++) {
                    const row = [];
                    for (let c = 0; c < other.width; c++) {
                        let sum = Complex.zero();
                        for (let k = 0; k < this.width; k++) {
                            sum = sum.add(this.rows[r][k].mul(other.rows[k][c]));
                        }
                        row.push(sum);
                    }
                    output.push(row);
                }
                return new Matrix(output);
            }

            multiplyVector(vector) {
                if (this.width !== vector.length) throw new Error("Matrix and vector dimensions do not match");
                const output = [];
                for (let r = 0; r < this.height; r++) {
                    let sum = Complex.zero();
                    for (let c = 0; c < this.width; c++) sum = sum.add(this.rows[r][c].mul(vector[c]));
                    output.push(sum);
                }
                return output;
            }

            tensor(other) {
                const rows = [];
                for (let ar = 0; ar < this.height; ar++) {
                    for (let br = 0; br < other.height; br++) {
                        const row = [];
                        for (let ac = 0; ac < this.width; ac++) {
                            for (let bc = 0; bc < other.width; bc++) {
                                row.push(this.rows[ar][ac].mul(other.rows[br][bc]));
                            }
                        }
                        rows.push(row);
                    }
                }
                return new Matrix(rows);
            }
        }

