                document.getElementById("removeQubit").addEventListener("click", () => this.safe(() => {
                    if (this.sensorActive) throw new Error("Sensor active: qubit count fixed to 1");
                    this.circuit.removeQubit();
                    this.renderCircuit();
                    this.runCircuit();
                }));
                document.getElementById("addColumn").addEventListener("click", () => {
                    this.circuit.columns++;
                    this.renderCircuit();
                });
                document.getElementById("runCircuit").addEventListener("click", () => this.runCircuit());
                document.getElementById("resetCircuit").addEventListener("click", () => {
                    this.circuit.clear();
                    this.collapsedState = null;
                    this.el.measurement.textContent = "No measurement yet";
                    this.renderCircuit();
                    this.runCircuit();
                });
                document.getElementById("randomCircuit").addEventListener("click", () => this.randomCircuit());
                document.getElementById("measureAll").addEventListener("click", () => this.measureAll());
                document.getElementById("exportJson").addEventListener("click", () => this.el.exportText.value = CircuitExport.json(this.circuit));
                document.getElementById("exportQasm").addEventListener("click", () => this.el.exportText.value = CircuitExport.openQASM(this.circuit));
                document.getElementById("exportQiskit").addEventListener("click", () => this.el.exportText.value = CircuitExport.qiskit(this.circuit));
                document.getElementById("importJson").addEventListener("click", () => this.importJson());
                document.getElementById("buildCircuitFromCode").addEventListener("click", () => this.buildCircuitFromCode(false));
                document.getElementById("runImportedCircuit").addEventListener("click", () => this.buildCircuitFromCode(true));

                // ---- SENSOR EVENTS (new) ----
                this.el.sensorStartBtn.addEventListener("click", () => this.startSensor());
                this.el.sensorStopBtn.addEventListener("click", () => this.stopSensor());

                window.addEventListener("resize", () => {
                    if (this.lastResult) Visualization.renderAmplitudeCanvas(this.el.ampCanvas, this.getDisplayedState());
                    this.resizeSpectrometer();
                });
            },

            resizeSpectrometer() {
                const w = this.el.specCanvas.clientWidth || 340;
                this.el.specCanvas.width = w;
                this.el.specCanvas.height = 90;
            },

            safe(fn) {
                try {
                    fn();
                    this.setStatus("Ready");
                } catch (error) {
                    this.setStatus(error.message, true);
                }
            },

            setStatus(message, isError = false) {
                this.el.status.textContent = message;
                this.el.status.classList.toggle("error", isError);
            },

            // ---- ORIGINAL EMULATOR METHODS (unchanged) ----
            renderPalette() {
                this.el.palette.innerHTML = "";
                Object.values(GateLibrary).forEach((gate) => {
                    const button = document.createElement("button");
                    button.className = "gate-chip";
                    button.draggable = true;
                    button.style.setProperty("--gate-color", gate.color);
                    button.textContent = gate.name;
                    button.title = `${gate.name} gate`;
                    button.addEventListener("click", () => {
                        this.selectedGate = gate.name;
                        document.querySelectorAll(".gate-chip").forEach((b) => b.classList.remove("active"));
                        button.classList.add("active");
                    });
                    button.addEventListener("dragstart", (event) => event.dataTransfer.setData("text/plain", gate.name));
                    if (gate.name === this.selectedGate) button.classList.add("active");
                    this.el.palette.appendChild(button);
                });
            },

            renderCircuit() {
                this.el.qCount.textContent = this.circuit.numQubits;
                this.el.columns.textContent = this.circuit.columns;
                this.el.grid.innerHTML = "";
                this.el.grid.style.gridTemplateColumns = `92px repeat(${this.circuit.columns}, minmax(54px, 1fr))`;
                for (let q = this.circuit.numQubits - 1; q >= 0; q--) {
                    const label = document.createElement("div");
                    label.className = "qubit-label";
                    label.textContent = `q${q}`;
                    this.el.grid.appendChild(label);
                    for (let c = 0; c < this.circuit.columns; c++) {
                        this.el.grid.appendChild(this.cell(c, q));
                    }
                }
                this.drawConnectors();
                this.renderStats();
            },

            cell(column, qubit) {
                const cell = document.createElement("div");
                cell.className = "circuit-cell";
                cell.dataset.column = column;
                cell.dataset.qubit = qubit;
                const wire = document.createElement("div");
                wire.className = "wire";
                cell.appendChild(wire);
                const gate = this.circuit.gateAt(column, qubit);
                if (gate) {
                    const node = document.createElement("button");
                    node.className = `gate-node ${gate.targets.length === 2 ? "multi" : ""}`;
                    node.style.background = GateLibrary[gate.type].color;
                    node.textContent = gate.type === "CNOT" ? (gate.targets[0] === qubit ? "C" : "X") : gate.type;
                    node.title = "Click to remove gate";
                    node.addEventListener("click", (event) => {
                        event.stopPropagation();
                        this.circuit.removeGate(gate.id);
                        this.pendingTwoQubit = null;
                        this.renderCircuit();
                        this.runCircuit();
                    });
                    cell.appendChild(node);
                }
                cell.addEventListener("dragover", (event) => event.preventDefault());
                cell.addEventListener("drop", (event) => {
                    event.preventDefault();
                    this.placeGate(event.dataTransfer.getData("text/plain") || this.selectedGate, column, qubit);
                });
                cell.addEventListener("click", () => this.placeGate(this.selectedGate, column, qubit));
                return cell;
            },

            drawConnectors() {
                this.circuit.gates.filter((gate) => gate.targets.length === 2).forEach((gate) => {
                    const [a, b] = gate.targets;
                    const top = Math.max(a, b);
                    const low = Math.min(a, b);
                    for (let q = low + 1; q < top; q++) {
                        const cell = this.el.grid.querySelector(`[data-column="${gate.column}"][data-qubit="${q}"]`);
                        if (cell) cell.classList.add("connector");
                    }
                });
            },

            placeGate(type, column, qubit) {
                this.safe(() => {
                    const gate = GateLibrary[type];
                    if (!gate) throw new Error("Choose a valid gate");
                    if (gate.arity === 1) {
                        this.circuit.addGate(type, column, [qubit]);
                    } else {
                        if (!this.pendingTwoQubit || this.pendingTwoQubit.type !== type || this.pendingTwoQubit.column !== column) {
                            this.pendingTwoQubit = { type, column, first: qubit };
                            this.setStatus(`Select second qubit for ${type} in column ${column}`);
                            return;
                        }
                        this.circuit.addGate(type, column, [this.pendingTwoQubit.first, qubit]);
                        this.pendingTwoQubit = null;
                    }
                    this.collapsedState = null;
                    this.renderCircuit();
                    this.runCircuit();
                });
            },

            runCircuit() {
                this.safe(() => {
                    this.lastResult = Simulator.run(this.circuit);
                    this.collapsedState = null;
                    this.el.timing.textContent = `${this.lastResult.elapsedMs.toFixed(3)} ms`;
                    this.el.gateCount.textContent = this.lastResult.gateCount;
                    // If sensor is active, apply its state to the simulation result
                    if (this.sensorActive && this.sensorState !== 'IDLE') {
                        this.lastResult.state.setSensorState(this.sensorState);
                    }
                    this.updateVisuals(this.lastResult.state);
                    this.setStatus(this.lastResult.status);
                });
            },

            getDisplayedState() {
                return this.collapsedState || (this.lastResult && this.lastResult.state);
            },

            updateVisuals(state) {
                Visualization.renderProbabilityChart(this.el.probChart, state.probabilities());
                Visualization.renderStateTable(this.el.stateTable, state);
                Visualization.renderAmplitudeCanvas(this.el.ampCanvas, state);
                this.renderStats();
            },

            renderStats() {
                const stats = this.circuit.stats();
                this.el.stats.innerHTML = "";
                Object.entries(stats).forEach(([name, count]) => {
                    const item = document.createElement("div");
                    item.className = "stat-pill";
                    item.innerHTML = `<span>${name}</span><strong>${count}</strong>`;
                    this.el.stats.appendChild(item);
                });
            },

            measureAll() {
                this.safe(() => {
                    if (!this.lastResult) this.runCircuit();
                    this.collapsedState = this.lastResult.state.clone();
                    const result = this.collapsedState.measure();
                    this.el.measurement.textContent = `${result.bitstring} (${(result.probability * 100).toFixed(3)}%)`;
                    this.updateVisuals(this.collapsedState);
                    this.setStatus("Measurement collapsed the state vector");
                });
            },

            randomCircuit() {
                this.safe(() => {
                    this.circuit.clear();
                    const names = Object.keys(GateLibrary);
                    const depth = Math.min(this.circuit.columns, 5 + Math.floor(Math.random() * 5));
                    for (let c = 0; c < depth; c++) {
                        const attempts = 1 + Math.floor(Math.random() * this.circuit.numQubits);
                        for (let a = 0; a < attempts; a++) {
                            const available = this.circuit.numQubits < 2 ? names.filter((name) => GateLibrary[name].arity === 1) : names;
                            const type = available[Math.floor(Math.random() * available.length)];
                            const arity = GateLibrary[type].arity;
                            const targets = [];
                            while (targets.length < arity) {
                                const q = Math.floor(Math.random() * this.circuit.numQubits);
                                if (!targets.includes(q)) targets.push(q);
                            }
                            try { this.circuit.addGate(type, c, targets); } catch (_) {}
                        }
                    }
                    this.renderCircuit();
                    this.runCircuit();
                });
            },

            importJson() {
                this.safe(() => {
                    const imported = Circuit.fromJSON(this.el.importText.value);
                    this.circuit = imported;
                    this.pendingTwoQubit = null;
                    this.collapsedState = null;
                    this.renderCircuit();
                    this.runCircuit();
                });
            },

            parseCircuitCode(text) {
                const gates = [];
                const lines = text.split(/\r?\n/);
                const singleQiskit = /^qc\.(x|y|z|h|s|t)\s*\(\s*([0-7])\s*\)\s*;?$/i;
                const doubleQiskit = /^qc\.(cx|cnot|swap)\s*\(\s*([0-7])\s*,\s*([0-7])\s*\)\s*;?$/i;
                const singleQasm = /^(x|y|z|h|s|t)\s+q\s*\[\s*([0-7])\s*\]\s*;?$/i;
                const doubleQasm = /^(cx|cnot|swap)\s+q\s*\[\s*([0-7])\s*\]\s*,\s*q\s*\[\s*([0-7])\s*\]\s*;?$/i;

                lines.forEach((rawLine, index) => {
                    const line = rawLine.replace(/\/\/.*$/, "").replace(/#.*$/, "").trim();
                    if (!line || /^OPENQASM\b/i.test(line) || /^include\b/i.test(line) || /^(qreg|creg)\b/i.test(line) || /^measure\b/i.test(line)) return;
                    let match = line.match(singleQiskit) || line.match(singleQasm);
                    if (match) {
                        gates.push({ type: match[1].toUpperCase(), targets: [Number(match[2])] });
                        return;
                    }
                    match = line.match(doubleQiskit) || line.match(doubleQasm);
                    if (match) {
                        const type = match[1].toUpperCase() === "CX" || match[1].toUpperCase() === "CNOT" ? "CNOT" : "SWAP";
                        const targets = [Number(match[2]), Number(match[3])];
                        if (targets[0] === targets[1]) throw new Error(`Line ${index + 1}: ${type} requires two different qubits`);
                        gates.push({ type, targets });
                        return;
                    }
                    throw new Error(`Line ${index + 1}: invalid circuit syntax "${rawLine.trim()}"`);
                });

                if (!gates.length) throw new Error("Circuit Code Input is empty or contains no supported gates");
                const maxQubit = Math.max(...gates.flatMap((gate) => gate.targets));
                if (maxQubit > 7) throw new Error("Only qubits 0 through 7 are supported");
                return { gates, numQubits: maxQubit + 1 };
            },

            buildCircuitFromCode(runAfterBuild = false) {
                this.safe(() => {
                    const parsed = this.parseCircuitCode(this.el.circuitCodeInput.value);
                    const importedCircuit = new Circuit(parsed.numQubits, Math.max(8, parsed.gates.length));
                    parsed.gates.forEach((gate, column) => importedCircuit.addGate(gate.type, column, gate.targets));
                    this.circuit = importedCircuit;
                    this.pendingTwoQubit = null;
                    this.collapsedState = null;
                    this.el.measurement.textContent = "No measurement yet";
                    this.renderCircuit();
                    if (runAfterBuild) this.runCircuit();
                    this.el.circuitCodeMessage.textContent = runAfterBuild ? "Circuit built and executed" : "Circuit built successfully";
                    this.el.circuitCodeMessage.classList.remove("error");
                });
                if (this.el.status.classList.contains("error")) {
                    this.el.circuitCodeMessage.textContent = this.el.status.textContent;
                    this.el.circuitCodeMessage.classList.add("error");
                }
            },

            // ============================================================
            // 3. SENSOR INTEGRATION (from second code, adapted)
            // ============================================================

            initSensor() {
                this.resizeSpectrometer();
                this.el.specCtx.fillStyle = "black";
                this.el.specCtx.fillRect(0, 0, this.el.specCanvas.width, this.el.specCanvas.height);
                this.updateSensorUI('IDLE', false, false);
            },

            startSensor() {
                if (this.sensorActive) return;
                // Force circuit to 1 qubit (matching physical hardware)
                while (this.circuit.numQubits > 1) {
                    this.circuit.removeQubit();
                }
                this.renderCircuit();
                document.getElementById("addQubit").disabled = true;
                document.getElementById("removeQubit").disabled = true;

                navigator.mediaDevices.getUserMedia({
                    video: { facingMode: "environment", frameRate: { ideal: 60 } }
                }).then(stream => {
                    this.el.video.srcObject = stream;
                    this.el.video.play();
                    this.sensorActive = true;
                    this.el.sensorStatusBadge.textContent = '● RUNNING';
                    this.el.sensorStatusBadge.className = 'sensor-status-badge on';
                    this.el.sensorStartBtn.textContent = 'RUNNING';
                    this.el.sensorStartBtn.disabled = true;
                    this.lastTime = Date.now();
                    this.pulses = 0;
                    this.sensorDetectLoop();
                }).catch(err => {
                    alert('Camera access denied. Please allow camera access.');
                    console.error(err);
                });
            },

            stopSensor() {
                this.sensorActive = false;
                if (this.sensorAnimId) {
                    cancelAnimationFrame(this.sensorAnimId);
                    this.sensorAnimId = null;
                }
                if (this.el.video.srcObject) {
                    this.el.video.srcObject.getTracks().forEach(t => t.stop());
                    this.el.video.srcObject = null;
                }
                this.el.sensorStatusBadge.textContent = '⏻ STOPPED';
                this.el.sensorStatusBadge.className = 'sensor-status-badge';
                this.el.sensorStartBtn.textContent = 'START';
                this.el.sensorStartBtn.disabled = false;
                document.getElementById("addQubit").disabled = false;
                document.getElementById("removeQubit").disabled = false;
                this.updateSensorUI('IDLE', false, false);
                // Reset emulator state to |0⟩ when sensor stops
                if (this.lastResult) {
                    this.lastResult.state.setSensorState('IDLE');
                    this.updateVisuals(this.lastResult.state);
                }
            },

            sensorDetectLoop() {
                if (!this.sensorActive) return;
                const ctx = this.el.ctx;
                const canvas = this.el.canvas;
                const video = this.el.video;
                if (video.readyState >= 2) {
                    ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
                    const data = ctx.getImageData(canvas.width / 2 - 20, canvas.height / 2 - 20, 40, 40).data;
                    const threshold = parseInt(this.el.sens.value);
                    let rH = 0,
                        wH = 0,
                        totalB = 0;
                    for (let i = 0; i < data.length; i += 4) {
                        let r = data[i],
                            g = data[i + 1],
                            b = data[i + 2];
                        totalB += (r + g + b) / 3;
                        if (r > threshold && g < threshold / 1.3) rH++;
                        if (r > threshold && g > threshold / 1.1 && b > threshold / 1.1) wH++;
                    }
                    const avgB = totalB / (data.length / 4);
                    if (Math.abs(avgB - this.lastBrightness) > 5) this.pulses++;
                    this.lastBrightness = avgB;

                    if (Date.now() - this.lastTime >= 1000) {
                        const multiplier = (rH > 8 && wH > 8) ? 42.5 : 22.1;
                        this.displayHz = Math.floor(this.pulses * multiplier);
                        const red = rH > 8,
                            white = wH > 8;
                        this.sensorDetectedRed = red;
                        this.sensorDetectedWhite = white;
                        let state = 'IDLE';
                        if (red && white) state = '|ψ⟩';
                        else if (red) state = '|0⟩';
                        else if (white) state = '|1⟩';
                        this.sensorState = state;
                        this.updateSensorUI(state, red, white);
                        // Sync sensor state to emulator
                        this.syncSensorToEmulator(state);
                        this.pulses = 0;
                        this.lastTime = Date.now();
                    }
                    this.drawSpectrometer(this.displayHz, rH > 8, wH > 8);
                }
                this.sensorAnimId = requestAnimationFrame(() => this.sensorDetectLoop());
            },

            drawSpectrometer(hz, hasRed, hasWhite) {
                const ctx = this.el.specCtx;
                const w = this.el.specCanvas.width,
                    h = this.el.specCanvas.height;
                ctx.fillStyle = "black";
                ctx.fillRect(0, 0, w, h);
                this.rWave.shift();
                this.wWave.shift();
                const time = Date.now() / 50;
                const isMixing = hasRed && hasWhite;
                let rPos = hasRed ? 100 + (Math.sin(time) * (hz * 0.15)) : 120;
                let wPos = hasWhite ? 40 + (Math.cos(time) * (hz * 0.15)) : 30;
                if (isMixing) { rPos -= 30;
                    wPos += 30; }
                this.rWave.push(rPos);
                this.wWave.push(wPos);

                ctx.lineWidth = 2;
                ctx.beginPath();
                ctx.strokeStyle = "#ffffff";
                for (let i = 0; i < 100; i++) ctx.lineTo((w / 100) * i, Math.min(h - 2, Math.max(2, this.wWave[i])));
                ctx.stroke();

                ctx.beginPath();
                ctx.strokeStyle = "#ff4b2b";
                for (let i = 0; i < 100; i++) ctx.lineTo((w / 100) * i, Math.min(h - 2, Math.max(2, this.rWave[i])));
                ctx.stroke();

                let rotX = isMixing ? Math.sin(time / 2.5) * 40 : (hasRed ? 25 : (hasWhite ? -25 : 0));
                let rotY = isMixing ? Math.cos(time / 2.5) * 40 : (hasRed ? 45 : (hasWhite ? -45 : 0));
                this.el.vectorCircle.style.transform = `rotateX(${rotX}deg) rotateY(${rotY}deg)`;

                let baseRotate = this.displayHz * 0.8;
                this.el.nMain.style.transform = `rotate(${baseRotate}deg) translateZ(35px)`;
                this.el.nRed.style.opacity = hasRed ? "1" : "0.05";
                this.el.nWhite.style.opacity = hasWhite ? "1" : "0.05";
            },

            updateSensorUI(state, red, white) {
                const el = this.el;
                const statusMap = {
                    '|0⟩': 'GROUND STATE |0⟩',
                    '|1⟩': 'EXCITED STATE |1⟩',
                    '|ψ⟩': 'SUPERPOSITION |ψ⟩',
                    'IDLE': 'VACUUM IDLE'
                };
                el.qStatus.textContent = statusMap[state] || 'IDLE';

                const freqMap = {
                    '|0⟩': '484 THz',
                    '|1⟩': '790 THz',
                    '|ψ⟩': 'RED: 484 THz | WHITE: 790 THz',
                    'IDLE': '0 Hz'
                };
                el.hzText.textContent = freqMap[state] || '0 Hz';

                const detectMap = {
                    '|0⟩': 'Low Frequency Red Active',
                    '|1⟩': 'High Frequency White Active',
                    '|ψ⟩': 'Dual Phase Coherence Detected',
                    'IDLE': 'Scanning for Quantum Gates…'
                };
                el.detectText.textContent = detectMap[state] || 'Scanning…';

                const symMap = { '|0⟩': '0', '|1⟩': '1', '|ψ⟩': 'Ψ', 'IDLE': '' };
                el.qSym.textContent = symMap[state] || '';

                document.querySelectorAll('.truth-table tr').forEach(r => r.classList.remove('active-row'));
                const showEv = (id) => { const e = document.getElementById(id); if (e) e.style.display = 'inline'; };
                const hideEv = (id) => { const e = document.getElementById(id); if (e) e.style.display = 'none'; };
                hideEv('ev-red');
                hideEv('ev-white');
                hideEv('ev-super');

                if (state === '|ψ⟩') {
                    el.rowSuper.classList.add('active-row');
                    el.fSuper.textContent = '484 & 790';
                    el.fRed.textContent = '484';
                    el.fWhite.textContent = '790';
                    el.fSuper.classList.add('val-changing');
                    showEv('ev-red');
                    showEv('ev-white');
                    showEv('ev-super');
                } else if (state === '|0⟩') {
                    el.rowRed.classList.add('active-row');
                    el.fRed.textContent = '484';
                    el.fRed.classList.add('val-changing');
                    el.fWhite.textContent = '0';
                    el.fSuper.textContent = '0';
                    showEv('ev-red');
                } else if (state === '|1⟩') {
                    el.rowWhite.classList.add('active-row');
                    el.fWhite.textContent = '790';
                    el.fWhite.classList.add('val-changing');
                    el.fRed.textContent = '0';
                    el.fSuper.textContent = '0';
                    showEv('ev-white');
                } else {
                    el.fRed.textContent = '0';
                    el.fWhite.textContent = '0';
                    el.fSuper.textContent = '0';
                    el.fRed.classList.remove('val-changing');
                    el.fWhite.classList.remove('val-changing');
                    el.fSuper.classList.remove('val-changing');
                }
            },

            syncSensorToEmulator(state) {
                // Update the emulator's state to match sensor
                if (!this.lastResult) {
                    // Create a dummy simulation result with 1 qubit
                    this.lastResult = { state: new QuantumState(1) };
                }
                const currentState = this.lastResult.state;
                if (currentState.numQubits !== 1) {
                    // Force 1 qubit (should already be the case)
                    const newState = new QuantumState(1);
                    newState.setSensorState(state);
                    this.lastResult.state = newState;
                } else {
                    currentState.setSensorState(state);
                }
                this.collapsedState = null;
                this.updateVisuals(this.lastResult.state);
                this.setStatus(`Sensor → ${state}`);
            }
        };

        document.addEventListener("DOMContentLoaded", () => {
            app.init();
        });
    </script>

