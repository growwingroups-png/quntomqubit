            static renderAmplitudeCanvas(canvas, state) {
                const dpr = window.devicePixelRatio || 1;
                const rect = canvas.getBoundingClientRect();
                canvas.width = Math.max(1, Math.floor(rect.width * dpr));
                canvas.height = Math.max(1, Math.floor(rect.height * dpr));
                const ctx = canvas.getContext("2d");
                ctx.scale(dpr, dpr);
                ctx.clearRect(0, 0, rect.width, rect.height);
                ctx.strokeStyle = "rgba(255,255,255,.12)";
                ctx.beginPath();
                ctx.moveTo(0, rect.height / 2);
                ctx.lineTo(rect.width, rect.height / 2);
                ctx.stroke();
                const amps = state.amplitudes;
                const gap = 4;
                const width = Math.max(3, (rect.width - gap * (amps.length - 1)) / amps.length);
                amps.forEach((amp, i) => {
                    const magnitude = amp.abs();
                    const phase = amp.phase();
                    const hue = ((phase + Math.PI) / (2 * Math.PI)) * 320 + 20;
                    const h = magnitude * (rect.height * 0.45);
                    const x = i * (width + gap);
                    ctx.fillStyle = `hsl(${hue}, 76%, 62%)`;
                    ctx.fillRect(x, rect.height / 2 - h, width, h);
                    ctx.fillStyle = "rgba(255,255,255,.45)";
                    ctx.fillRect(x, rect.height / 2, width, Math.max(1, amp.abs2() * rect.height * 0.45));
                });
            }
        }

