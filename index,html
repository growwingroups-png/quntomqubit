        class Simulator {
            static run(circuit) {
                const started = performance.now();
                const state = new QuantumState(circuit.numQubits);
                const gates = circuit.gates.slice().sort((a, b) => a.column - b.column);
                for (const gate of gates) {
                    this.applyGate(state, gate);
                }
                state.normalize();
                return {
                    state,
                    elapsedMs: performance.now() - started,
                    gateCount: gates.length,
                    status: "Simulation complete"
                };
            }

            static applyGate(state, gate) {
                const lib = GateLibrary[gate.type];
                if (!lib) throw new Error(`Unsupported gate ${gate.type}`);
                if (lib.arity === 1) {
                    state.applySingleQubitGate(lib.matrix, gate.targets[0]);
                    return;
                }
                if (gate.type === "CNOT") {
                    state.applyCNOT(gate.targets[0], gate.targets[1]);
                    return;
                }
                if (gate.type === "SWAP") {
                    state.applySWAP(gate.targets[0], gate.targets[1]);
                    return;
                }
                throw new Error(`Gate ${gate.type} is not implemented`);
            }
        }

