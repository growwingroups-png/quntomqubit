        class Circuit {
            constructor(numQubits = 2, columns = 8) {
                this.numQubits = numQubits;
                this.columns = columns;
                this.gates = [];
            }

            validateQubit(qubit) {
                if (!Number.isInteger(qubit) || qubit < 0 || qubit >= this.numQubits) {
                    throw new Error(`Qubit ${qubit} is out of range`);
                }
            }

            addQubit() {
                if (this.numQubits >= 8) throw new Error("Maximum of 8 qubits reached");
                this.numQubits++;
            }

            removeQubit() {
                if (this.numQubits <= 1) throw new Error("At least one qubit is required");
                const removed = this.numQubits - 1;
                this.gates = this.gates.filter((gate) => !gate.targets.includes(removed));
                this.numQubits--;
            }

            ensureColumn(column) {
                if (column >= this.columns) this.columns = column + 1;
            }

            canPlace(type, column, targets) {
                if (!GateLibrary[type]) throw new Error(`Unknown gate ${type}`);
                targets.forEach((target) => this.validateQubit(target));
                if (new Set(targets).size !== targets.length) return false;
                return !this.gates.some((gate) => gate.column === column && gate.targets.some((target) => targets.includes(target)));
            }

            addGate(type, column, targets) {
                if (!GateLibrary[type]) throw new Error(`Unknown gate ${type}`);
                const required = GateLibrary[type].arity;
                if (targets.length !== required) throw new Error(`${type} requires ${required} target${required > 1 ? "s" : ""}`);
                this.ensureColumn(column);
                if (!this.canPlace(type, column, targets)) throw new Error("Cell already contains a conflicting gate");
                const gate = {
                    id: crypto.randomUUID ? crypto.randomUUID() : `gate-${Date.now()}-${Math.random()}`,
                    type,
                    column,
                    targets: targets.slice()
                };
                this.gates.push(gate);
                this.sort();
                return gate;
            }

            removeGate(id) {
                this.gates = this.gates.filter((gate) => gate.id !== id);
            }

            gateAt(column, qubit) {
                return this.gates.find((gate) => gate.column === column && gate.targets.includes(qubit));
            }

            clear() {
                this.gates = [];
            }

            sort() {
                this.gates.sort((a, b) => a.column - b.column || Math.min(...a.targets) - Math.min(...b.targets));
            }

            stats() {
                const counts = Object.fromEntries(Object.keys(GateLibrary).map((name) => [name, 0]));
                this.gates.forEach((gate) => counts[gate.type]++);
                return counts;
            }

            toJSON() {
                return {
                    app: "GrowWin Quantum Emulator",
                    version: 1,
                    numQubits: this.numQubits,
                    columns: this.columns,
                    gates: this.gates.map(({ type, column, targets }) => ({ type, column, targets }))
                };
            }

            static fromJSON(data) {
                if (typeof data === "string") data = JSON.parse(data);
                if (!data || !Number.isInteger(data.numQubits) || !Array.isArray(data.gates)) {
                    throw new Error("Invalid circuit JSON");
                }
                const circuit = new Circuit(data.numQubits, Math.max(1, data.columns || 8));
                data.gates.forEach((gate) => circuit.addGate(gate.type, gate.column, gate.targets));
                return circuit;
            }
        }

